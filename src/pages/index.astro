---
import '../styles/global.css';

const projects = [
  {
    title: 'Playbooks',
    eyebrow: 'Operational guidance',
    description: 'Runbooks, migration notes, platform patterns, and implementation checklists.',
    status: 'forming'
  },
  {
    title: 'Reference Architectures',
    eyebrow: 'Design patterns',
    description: 'Practical diagrams and decision records for hybrid cloud, OpenShift, and platform engineering work.',
    status: 'drafting'
  },
  {
    title: 'Automation Templates',
    eyebrow: 'Reusable starting points',
    description: 'GitHub Actions, CI/CD scaffolds, infrastructure automation, and repeatable engineering workflows.',
    status: 'planned'
  },
  {
    title: 'Workspaces',
    eyebrow: 'Client delivery',
    description: 'Private project spaces for shared docs, handoff notes, implementation artifacts, and technical collaboration.',
    status: 'private'
  }
];

const notes = [
  'Internal platforms should be open enough to evolve without becoming uncontrolled.',
  'Automation accelerates delivery, but engineering judgment decides what should be automated.',
  'Good modernization creates a bridge between current operational reality and future architecture.',
  'The best platform work reduces friction without hiding the system from the people who operate it.'
];
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="InnerOpen Engineering — projects, playbooks, reference architectures, automation, and technical workspaces." />
    <title>InnerOpen Engineering</title>
  </head>
  <body>
    <div class="shell">
      <header class="site-header">
        <a class="brand" href="/" aria-label="InnerOpen Engineering home">
          <span class="brand-mark">IO</span>
          <span>
            <strong>InnerOpen</strong>
            <small>Engineering</small>
          </span>
        </a>
        <nav aria-label="Main navigation">
          <a href="#projects">Projects</a>
          <a href="#notes">Notes</a>
          <a href="#access">Access</a>
          <a href="https://inneropen.com">.com</a>
        </nav>
      </header>

      <main>
        <section class="hero">
          <p class="kicker">inneropen.io</p>
          <h1>Technical workspaces for open, operable infrastructure.</h1>
          <p class="lede">
            The engineering side of InnerOpen: project notes, reusable patterns, automation scaffolds,
            reference architectures, and private client workspaces.
          </p>
          <div class="hero-actions">
            <a class="button primary" href="https://github.com/inneropen">GitHub Organization</a>
            <a class="button secondary" href="https://inneropen.com">Consulting Site</a>
          </div>
        </section>

        <section class="command-line" aria-label="InnerOpen command line concept">
          <div class="terminal-bar">
            <span></span><span></span><span></span>
          </div>
          <pre><code>$ inneropen status
surface: engineering
mode: practical
focus: platforms · automation · interoperability · delivery
state: building</code></pre>
        </section>

        <section id="projects" class="section">
          <div class="section-heading">
            <p class="kicker">Projects</p>
            <h2>A place for the work behind the work.</h2>
          </div>
          <div class="grid">
            {projects.map((project) => (
              <article class="card">
                <div class="card-topline">
                  <span>{project.eyebrow}</span>
                  <span class="status">{project.status}</span>
                </div>
                <h3>{project.title}</h3>
                <p>{project.description}</p>
              </article>
            ))}
          </div>
        </section>

        <section id="notes" class="section split">
          <div>
            <p class="kicker">Engineering Notes</p>
            <h2>Small principles for systems that have to keep working.</h2>
          </div>
          <div class="notes-list">
            {notes.map((note, index) => (
              <article>
                <span>EN-{String(index + 1).padStart(3, '0')}</span>
                <p>{note}</p>
              </article>
            ))}
          </div>
        </section>

        <section id="access" class="section access-panel">
          <div>
            <p class="kicker">Access</p>
            <h2>For now, this is a landing zone.</h2>
            <p>
              Public repositories will appear as they’re ready. Client workspaces and delivery artifacts
              remain private by default and are shared by invitation.
            </p>
          </div>
          <a class="button primary" href="mailto:hello@inneropen.com">Request access</a>
        </section>
      </main>

      <footer>
        <span>© {new Date().getFullYear()} InnerOpen</span>
        <span>Open systems. Inner strength.</span>
      </footer>
    </div>
  </body>
</html>
