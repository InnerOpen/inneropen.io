---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ProjectCard from '../components/ProjectCard.astro';
import Card from '../components/Card.astro';
import Terminal from '../components/Terminal.astro';
import Button from '../components/Button.astro';
import Kicker from '../components/Kicker.astro';
import { getCollection } from 'astro:content';

// Get featured work areas
const allWorkAreas = await getCollection('work-areas');
const featuredWorkAreas = allWorkAreas
  .filter((w) => w.data.featured)
  .sort((a, b) => a.data.order - b.data.order);

// Get current projects (featured or alpha+)
const allProjects = await getCollection('projects');
const currentProjects = allProjects
  .filter((p) => p.data.featured || ['alpha', 'beta', 'stable', 'maintenance'].includes(p.data.maturity))
  .slice(0, 4);

// Get latest updates
const allUpdates = await getCollection('updates', ({ data }) => !data.draft);
const latestUpdates = allUpdates
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 6);

// Get recent notes
const allNotes = await getCollection('notes', ({ data }) => data.status === 'published');
const recentNotes = allNotes
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 4);

// Helper to extract note number from title
const getNoteNumber = (title: string) => {
  const parts = title.split(/\s*[—-]\s*/);
  return parts[0] || title;
};
---

<BaseLayout
  title="InnerOpen Engineering"
  description="InnerOpen Engineering — projects, technical notes, automation, and open infrastructure work."
>
  <Header />

  <main>
    <section class="hero">
      <Kicker>inneropen.io</Kicker>
      <h1>Technical workspaces for open, operable infrastructure.</h1>
      <p class="lede">
        The engineering side of InnerOpen: project notes, reusable patterns, automation scaffolds,
        reference architectures, and open technical work.
      </p>
      <div class="hero-actions">
        <Button href="https://github.com/inneropen" variant="primary">GitHub Organization</Button>
        <Button href="https://inneropen.com" variant="secondary">Consulting Site</Button>
      </div>
    </section>

    <Terminal>$ inneropen status
surface: engineering
mode: practical
focus: platforms · automation · interoperability · delivery
state: building</Terminal>

    {featuredWorkAreas.length > 0 && (
      <section class="section">
        <div class="section-heading">
          <Kicker>Featured Work</Kicker>
          <h2>Engineering across platforms and automation.</h2>
        </div>
        <div class="grid">
          {featuredWorkAreas.map((area) => (
            <Card href={`/work/${area.data.slug}`}>
              <div class="card-topline">
                <span>{area.data.summary}</span>
                <span class="status">{area.data.status}</span>
              </div>
              <h3>{area.data.title}</h3>
              <p>{area.data.description}</p>
            </Card>
          ))}
        </div>
      </section>
    )}

    {currentProjects.length > 0 && (
      <section class="section">
        <div class="section-heading">
          <Kicker>Current Projects</Kicker>
          <h2>Active development and stable releases.</h2>
        </div>
        <div class="grid">
          {currentProjects.map((project) => (
            <ProjectCard
              title={project.data.title}
              eyebrow={project.data.summary}
              description={project.data.description}
              status={project.data.status}
              maturity={project.data.maturity}
              href={`/work/${project.data.family}/${project.data.slug}`}
            />
          ))}
        </div>
      </section>
    )}

    {latestUpdates.length > 0 && (
      <section class="section">
        <div class="section-heading">
          <Kicker>Latest Updates</Kicker>
          <h2>Recent releases and milestones.</h2>
        </div>
        <div class="grid">
          {latestUpdates.map((update) => (
            <Card href={`/updates/${update.id}`}>
              <div class="card-topline">
                <span>{update.data.type}</span>
                {update.data.version && <span class="status">v{update.data.version}</span>}
              </div>
              <h3>{update.data.title}</h3>
              <p>{update.data.description}</p>
            </Card>
          ))}
        </div>
      </section>
    )}

    {recentNotes.length > 0 && (
      <section class="section split">
        <div>
          <Kicker>Engineering Notes</Kicker>
          <h2>Small principles for systems that have to keep working.</h2>
        </div>
        <div class="notes-list">
          {recentNotes.map((note) => (
            <article>
              <a href={`/notes/${note.id}`}>
                <span>{getNoteNumber(note.data.title)}</span>
                <p>{note.data.description}</p>
              </a>
            </article>
          ))}
        </div>
      </section>
    )}

    <section class="section access-panel">
      <div>
        <Kicker>Stay Updated</Kicker>
        <h2>Follow InnerOpen engineering work.</h2>
        <p>
          Public repositories, release updates, and engineering notes are published as they are ready.
          Subscribe to the RSS feed or follow on GitHub for updates.
        </p>
      </div>
      <Button href="/rss.xml" variant="primary">RSS Feed</Button>
    </section>
  </main>

  <Footer />
</BaseLayout>

<style>
  .notes-list article a {
    display: block;
  }

  .notes-list article a:hover {
    opacity: 0.8;
  }
</style>
