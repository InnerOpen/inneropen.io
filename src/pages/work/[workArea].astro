---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import ProjectCard from '../../components/ProjectCard.astro';
import Card from '../../components/Card.astro';
import Kicker from '../../components/Kicker.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const workAreas = await getCollection('work-areas');

  return workAreas.map((area) => ({
    params: { workArea: area.data.slug },
    props: { area },
  }));
}

const { area } = Astro.props;
const { Content } = await render(area);

// Get projects for this work area
const allProjects = await getCollection('projects');
const projects = allProjects.filter((p) => p.data.family === area.data.slug);

// Get recent updates for this work area
const allUpdates = await getCollection('updates', ({ data }) => !data.draft);
const updates = allUpdates
  .filter((u) => u.data.workArea === area.data.slug)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 6);
---

<BaseLayout
  title={`${area.data.title} — InnerOpen Engineering`}
  description={area.data.description}
>
  <Header />

  <main>
    <section class="hero">
      <Kicker>{area.data.summary}</Kicker>
      <h1>{area.data.title}</h1>
      <p class="lede">{area.data.description}</p>
    </section>

    <section class="section">
      <div class="content-body">
        <Content />
      </div>
    </section>

    {projects.length > 0 && (
      <section class="section">
        <div class="section-heading">
          <Kicker>Projects</Kicker>
          <h2>{area.data.title} projects</h2>
        </div>
        <div class="grid">
          {projects.map((project) => (
            <ProjectCard
              title={project.data.title}
              eyebrow={project.data.summary}
              description={project.data.description}
              status={project.data.status}
              maturity={project.data.maturity}
              href={`/work/${area.data.slug}/${project.data.slug}`}
            />
          ))}
        </div>
      </section>
    )}

    {updates.length > 0 && (
      <section class="section">
        <div class="section-heading">
          <Kicker>Recent Updates</Kicker>
          <h2>Latest from {area.data.title}</h2>
        </div>
        <div class="grid">
          {updates.map((update) => (
            <Card href={`/updates/${update.id}`}>
              <div class="card-topline">
                <span>{update.data.type}</span>
                <span class="status">{new Date(update.data.date).toLocaleDateString()}</span>
              </div>
              <h3>{update.data.title}</h3>
              <p>{update.data.description}</p>
            </Card>
          ))}
        </div>
      </section>
    )}
  </main>

  <Footer />
</BaseLayout>

<style>
  .content-body {
    max-width: 820px;
    color: var(--muted);
    line-height: 1.65;
  }

  .content-body :global(h2) {
    color: var(--text);
    margin-top: 48px;
  }

  .content-body :global(ul) {
    margin-left: 24px;
  }
</style>
