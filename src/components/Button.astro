---
interface Props {
  href?: string;
  variant?: 'primary' | 'secondary';
  type?: 'button' | 'submit' | 'reset';
}

const { href, variant = 'primary', type = 'button' } = Astro.props;
const Element = href ? 'a' : 'button';
---

<Element
  href={href}
  type={href ? undefined : type}
  class={`button ${variant}`}
>
  <slot />
</Element>
